generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // (ou "postgresql" pour Render plus tard)
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  pseudo    String   @unique
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}
